electron_mirror=https://npmmirror.com/mirrors/electron/
electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/

# electron-builder 在打包时会遍历 node_modules 收集 production dependencies
# 及其传递依赖。pnpm 默认的 isolated linker 把传递依赖放在 .pnpm/ 虚拟目录
# 下，electron-builder 识别不到 electron-updater → debug → ms 这条链的 ms，
# 导致生产启动时 "Cannot find module 'ms'"。切成 hoisted 后 node_modules
# 变扁平，electron-builder 的 file collector 就能正常工作。
node-linker=hoisted
