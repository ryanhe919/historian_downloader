# Electron / electron-builder binary downloads fall back to their
# official GitHub releases by default. If you're on a network where
# GitHub is slow or blocked, set these in YOUR ~/.npmrc or via env
# vars instead of pinning them in this repo:
#
#   electron_mirror=https://npmmirror.com/mirrors/electron/
#   electron_builder_binaries_mirror=https://npmmirror.com/mirrors/electron-builder-binaries/
#
# The old repo-level pin to npmmirror.com broke installs for anyone
# whose DNS / proxy couldn't reach that host (including some corporate
# networks in mainland China) — v0.1.0 devs hit ENOTFOUND on fresh
# Windows checkouts.

# electron-builder 在 pnpm 项目下的依赖 walker 不稳：即便用 node-linker=hoisted
# 也可能 walk 到 debug 后漏掉 debug→ms 这一跳（v0.0.6 的 asar 实测就缺 ms，
# 导致生产启动时 "Cannot find module 'ms'"）。shamefully-hoist=true 会把所有
# transitive 包 symlink 到顶层 node_modules/，electron-builder 无论按哪种策略
# 收集都能命中真实文件。这是 electron 社区最广泛验证过的 pnpm 兼容开关。
shamefully-hoist=true
