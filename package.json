{
  "name": "historiandownloader",
  "version": "0.1.1",
  "description": "Historian Downloader — Electron client for Proficy iFix / Wonderware InTouch historians",
  "main": "./out/main/index.js",
  "author": "ryanhe919",
  "homepage": "https://github.com/ryanhe919/historian_downloader",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "pnpm run sidecar:clean && pnpm run sidecar:build && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "sidecar:install": "python -m pip install -r python/requirements-build.txt",
    "sidecar:build": "cd python && python -m PyInstaller build/hd-sidecar.spec --noconfirm --distpath ../resources --workpath build-temp --clean",
    "sidecar:clean": "rimraf python/build-temp resources/hd-sidecar",
    "build:unpack": "pnpm run sidecar:clean && pnpm run sidecar:build && electron-vite build && electron-builder --dir",
    "build:win": "pnpm run sidecar:clean && pnpm run sidecar:build && pnpm run typecheck && electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@emotion/react": "^11.14.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@timeui/react": "^1.8.1",
    "debug": "^4.4.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.3.9",
    "ms": "^2.1.3",
    "zustand": "^5.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ]
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "rimraf": "^6.0.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
