# ── Node / Electron ────────────────────────────────────────────
node_modules
dist
out
.eslintcache
*.log*

# ── Python sidecar ─────────────────────────────────────────────
# uv-managed dev venv (production ships the PyInstaller exe, not this).
python/.venv/
# setuptools-injected metadata (auto-regenerated on `uv sync` / pip install).
*.egg-info/

# PyInstaller build artifacts.
.venv-build/
python/build-temp/
python/build/hd-sidecar/
python/dist/
python/__pycache__/
python/**/__pycache__/
python/**/*.pyc
python/.pytest_cache/
# Onedir output — electron-builder repacks this into the installer.
resources/hd-sidecar/
# Auto-generated by scripts/write-python-version.mjs (sync with package.json).
python/_generated_version.py

# ── OS / editor / tooling ──────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.claude/
